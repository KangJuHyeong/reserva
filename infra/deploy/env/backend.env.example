# Copy to /opt/reserva/env/backend.env on the server.
DB_HOST=mysql
DB_PORT=3306
DB_NAME=reserva
DB_USERNAME=reserva_app
DB_PASSWORD=change-me
FRONTEND_ORIGIN=https://your-frontend-domain.vercel.app
FRONTEND_ORIGIN_PATTERNS=https://your-project-git-*.vercel.app,https://your-project-*.vercel.app
JAVA_TOOL_OPTIONS=-Xms128m -Xmx256m -XX:+UseSerialGC
SEED_DEMO_DATA=false
